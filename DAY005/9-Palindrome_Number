class Solution {
    public boolean isPalindrome(int x) {
        int original = x;
        int rev = 0;
        if(x<0) {
            return false;
        }
        while(x<) {
            int digit = x%10;
            rev = rev*10 + digit;
            x /= 10;
        }
        return original == rev;
    }
}