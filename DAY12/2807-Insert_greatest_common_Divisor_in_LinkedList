class Solution {
    public ListNode insertGreatestCommonDivisors(ListNode head) {
        if(head.next==null){
            return head;
        }

        ListNode temp1=head;
        ListNode temp2=head.next;
        while(temp2!=null){
            int max=ldiv(temp1.val,temp2.val);
            ListNode newNode= new ListNode(max);

            temp1.next=newNode;
            newNode.next=temp2;

            temp1 = temp2;
            temp2 = temp2.next;
            
        }
        return head;
        

        
    }
    public int ldiv(int a,int b){
        while(b!=0){
            int temp=b;
            b=a%b;
            a=temp;
        }
        
        return a;
    }
}